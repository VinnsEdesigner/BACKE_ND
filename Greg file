
'use strict';

const base      = require('./base');
const tone      = require('./tone');
const memory    = require('./memory');
const codeStyle = require('./code-style');
const libraries = require('./libraries');
const flags     = require('./flags');
const context   = require('./context');
const logger    = require('../logger');

// ── INJECT ────────────────────────────────────────────────────────────────────
// Assembles ALL personality modules into a single system prompt block.
// Called by prompt.js before every agent request.

/**
 * Build the full personality block for a user.
 *
 * options: {
 *   toneMode?:   string,   // 'chat' | 'code' | 'explain' | 'review' | 'debug'
 *   requestMeta?: object,  // { repo, branch, taskId }
 * }
 *
 * Returns: full personality block string
 */
async function build(userId, options = {}) {
  const { toneMode = 'chat', requestMeta = {} } = options;

  const parts = [];

  try {
    // 1. Core identity (always present)
    parts.push(base.get());
    parts.push('');

    // 2. Tone for this request
    parts.push(tone.get(toneMode));
    parts.push('');

    // 3. Code style (parallel fetch)
    const [styleInstruction, libInstruction, memorySummary, contextBlock] =
      await Promise.all([
        codeStyle.toInstruction(userId),
        libraries.toInstruction(userId),
        memory.summarise(userId),
        context.build(userId, requestMeta),
      ]);

    if (styleInstruction) { parts.push(styleInstruction); parts.push(''); }
    if (libInstruction)   { parts.push(libInstruction);   parts.push(''); }
    if (memorySummary)    { parts.push(memorySummary);    parts.push(''); }
    if (contextBlock)     { parts.push(contextBlock);     parts.push(''); }

    // 4. Active flags summary (only if relevant flags differ from defaults)
    const userFlags = await flags.get(userId);
    const flagLines = [];
    if (userFlags.debug_mode)           flagLines.push('- Debug mode: ON (verbose reasoning)');
    if (!userFlags.confirmation_prompts) flagLines.push('- Confirmation prompts: OFF');
    if (userFlags.autonomous_mode)       flagLines.push('- Autonomous mode: ON (proceed without asking)');

    if (flagLines.length > 0) {
      parts.push('[ACTIVE FLAGS]');
      parts.push(...flagLines);
      parts.push('');
    }

  } catch (err) {
    logger.error('inject:build', 'Failed to build personality block', err);
    // Fallback — return just the base identity so agent still works
    return base.get();
  }

  return parts.join('\n').trim();
}

module.exports = { build };


