'use strict';

const Groq = require('groq-sdk');
const { GoogleGenerativeAI } = require('@google/generative-ai');
const logger = require('./logger');
const {
  MODELS,
  ENDPOINTS,
  RATE_LIMITS,
  PROVIDER_STATUS,
  PROVIDER_COOLDOWN,
  AGENT,
} = require('../utils/constants');

// ── MISTRAL GAP ENFORCERS (LAW 8) ────────────────────────────────────────────
// Two independent 1 RPS buckets — api.mistral.ai and codestral.mistral.ai

let lastMistralCall   = 0;
let lastCodestralCall = 0;

async function mistralGap() {
  const wait = RATE_LIMITS.MISTRAL_GAP_MS - (Date.now() - lastMistralCall);
  if (wait > 0) await new Promise((r) => setTimeout(r, wait));
  lastMistralCall = Date.now();
}

async function codestralGap() {
  const wait = RATE_LIMITS.CODESTRAL_GAP_MS - (Date.now() - lastCodestralCall);
  if (wait > 0) await new Promise((r) => setTimeout(r, wait));
  lastCodestralCall = Date.now();
}

// ── PROVIDER HEALTH STATE ─────────────────────────────────────────────────────

const health = {
  groq:        { status: PROVIDER_STATUS.OK, downUntil: 0 },
  mistral_chat:{ status: PROVIDER_STATUS.OK, downUntil: 0 },
  codestral:   { status: PROVIDER_STATUS.OK, downUntil: 0 },
  gemini:      { status: PROVIDER_STATUS.OK, downUntil: 0 },
  gemini_lite: { status: PROVIDER_STATUS.OK, downUntil: 0 },
  gemma_26b:   { status: PROVIDER_STATUS.OK, downUntil: 0 },
  gemma_31b:   { status: PROVIDER_STATUS.OK, downUntil: 0 },
};

function isUp(provider) {
  return Date.now() > health[provider].downUntil;
}

function markProvider(provider, type) {
  const cooldown = type === 'rate_limited'
    ? PROVIDER_COOLDOWN.RATE_LIMITED
    : PROVIDER_COOLDOWN.DOWN;
  health[provider].status    = type === 'rate_limited'
    ? PROVIDER_STATUS.RATE_LIMITED
    : PROVIDER_STATUS.DOWN;
  health[provider].downUntil = Date.now() + cooldown;
  logger.warn('ai', `Provider ${provider} marked ${type} for ${cooldown / 1000}s`);
}

function markOk(provider) {
  health[provider].status    = PROVIDER_STATUS.OK;
  health[provider].downUntil = 0;
}

// ── SDK CLIENTS (lazy init) ───────────────────────────────────────────────────

let _groq   = null;
let _gemini = null;

function groqClient() {
  if (!_groq) _groq = new Groq({ apiKey: process.env.GROQ_API_KEY });
  return _groq;
}

function geminiModel(modelName) {
  if (!_gemini) _gemini = new GoogleGenerativeAI(process.env.GEMINI_API_KEY);
  return _gemini.getGenerativeModel({ model: modelName });
}

// ── SCHEMA NORMALIZER ─────────────────────────────────────────────────────────
// All providers → { text, model, tokens_used }

function normalizeGroq(res, modelName) {
  return {
    text:        res.choices[0]?.message?.content || '',
    model:       modelName,
    tokens_used: res.usage?.total_tokens || 0,
  };
}

function normalizeMistral(data, modelName) {
  return {
    text:        data.choices[0]?.message?.content || '',
    model:       modelName,
    tokens_used: data.usage?.total_tokens || 0,
  };
}

function normalizeGemini(result, modelName) {
  return {
    text:        result.response.text() || '',
    model:       modelName,
    tokens_used: result.response.usageMetadata?.totalTokenCount || 0,
  };
}

// ── INDIVIDUAL CALLERS ────────────────────────────────────────────────────────

async function callGroq(messages, maxTokens) {
  const res = await groqClient().chat.completions.create({
    model:      MODELS.GROQ_BRAIN,
    messages,
    max_tokens: maxTokens,
    stream:     false,
  });
  markOk('groq');
  return normalizeGroq(res, MODELS.GROQ_BRAIN);
}

async function callMistralChat(model, messages, maxTokens) {
  await mistralGap(); // LAW 8 — always enforce gap
  const res = await fetch(ENDPOINTS.MISTRAL_CHAT, {
    method:  'POST',
    headers: {
      'Content-Type': 'application/json',
      Authorization:  `Bearer ${process.env.MISTRAL_API_KEY}`,
    },
    body: JSON.stringify({ model, messages, max_tokens: maxTokens, stream: false }),
  });
  const data = await res.json();
  if (!res.ok) {
    throw Object.assign(new Error(data.message || res.statusText), { status: res.status });
  }
  markOk('mistral_chat');
  return normalizeMistral(data, model);
}

async function callGemini(providerKey, modelName, messages, maxTokens) {
  // Convert messages array → flat prompt string (Gemini doesn't use roles natively here)
  const prompt = messages
    .map((m) => (m.role === 'system' ? m.content : `${m.role}: ${m.content}`))
    .join('\n');
  const model  = geminiModel(modelName);
  const result = await model.generateContent(prompt);
  markOk(providerKey);
  return normalizeGemini(result, modelName);
}

// ── FiM — Codestral Fill-in-Middle ───────────────────────────────────────────

async function fim(prefix, suffix, maxTokens = AGENT.CODESTRAL_MAX_TOKENS) {
  if (!isUp('codestral')) throw new Error('codestral_unavailable');

  try {
    await codestralGap(); // LAW 8 — independent gap enforcer
    const res = await fetch(ENDPOINTS.CODESTRAL_FIM, {
      method:  'POST',
      headers: {
        'Content-Type': 'application/json',
        Authorization:  `Bearer ${process.env.CODESTRAL_API_KEY}`,
      },
      body: JSON.stringify({
        model:      MODELS.CODESTRAL_FIM,
        prompt:     prefix,
        suffix,
        max_tokens: maxTokens,
        stop:       ['</s>'],
      }),
    });
    const data = await res.json();
    if (!res.ok) {
      if (res.status === 429) markProvider('codestral', 'rate_limited');
      else                    markProvider('codestral', 'down');
      throw new Error(data.message || res.statusText);
    }
    markOk('codestral');
    return {
      text:        data.choices[0]?.message?.content || '',
      model:       MODELS.CODESTRAL_FIM,
      tokens_used: data.usage?.total_tokens || 0,
    };
  } catch (err) {
    logger.error('ai:fim', 'Codestral FiM failed', err);
    throw err;
  }
}

// ── WATERFALL ─────────────────────────────────────────────────────────────────
// Order: groq → devstral → mistral-large → gemini-flash-lite → gemma-26b → gemma-31b → gemini-2.5-flash

async function complete(options = {}) {
  const {
    messages,
    maxTokens    = AGENT.MAX_TOKENS,
    preferCode   = false,
    systemPrompt = null,
  } = options;

  if (!messages || !messages.length) throw new Error('messages required');

  const msgs = systemPrompt
    ? [{ role: 'system', content: systemPrompt }, ...messages]
    : messages;

  // 1. Groq llama-3.3-70b (primary brain — skip if preferCode)
  if (!preferCode && isUp('groq')) {
    try {
      logger.debug('ai', 'Trying Groq llama-3.3-70b');
      const result = await callGroq(msgs, maxTokens);
      logger.info('ai', 'Groq succeeded', { tokens: result.tokens_used });
      return result;
    } catch (err) {
      const status = err.status || err.statusCode;
      if (status === 429) markProvider('groq', 'rate_limited');
      else                markProvider('groq', 'down');
      logger.warn('ai', 'Groq failed → next', { error: err.message });
    }
  }

  // 2. Devstral (code writing / preferCode entry point)
  if (isUp('mistral_chat')) {
    try {
      logger.debug('ai', 'Trying devstral-medium-2507');
      const result = await callMistralChat(MODELS.MISTRAL_CODE, msgs, maxTokens);
      logger.info('ai', 'Devstral succeeded', { tokens: result.tokens_used });
      return result;
    } catch (err) {
      if (err.status === 429) markProvider('mistral_chat', 'rate_limited');
      else                    markProvider('mistral_chat', 'down');
      logger.warn('ai', 'Devstral failed → next', { error: err.message });
    }
  }

  // 3. Mistral-large (fallback brain)
  if (isUp('mistral_chat')) {
    try {
      logger.debug('ai', 'Trying mistral-large-2512');
      const result = await callMistralChat(MODELS.MISTRAL_LARGE, msgs, maxTokens);
      logger.info('ai', 'Mistral-large succeeded', { tokens: result.tokens_used });
      return result;
    } catch (err) {
      if (err.status === 429) markProvider('mistral_chat', 'rate_limited');
      else                    markProvider('mistral_chat', 'down');
      logger.warn('ai', 'Mistral-large failed → next', { error: err.message });
    }
  }

  // 4. Gemini flash-lite (500 RPD fast fallback)
  if (isUp('gemini_lite')) {
    try {
      logger.debug('ai', 'Trying gemini-3.1-flash-lite-preview');
      const result = await callGemini('gemini_lite', MODELS.GEMINI_FLASH_LITE, msgs, maxTokens);
      logger.info('ai', 'Gemini flash-lite succeeded', { tokens: result.tokens_used });
      return result;
    } catch (err) {
      if (err.message?.includes('429')) markProvider('gemini_lite', 'rate_limited');
      else                              markProvider('gemini_lite', 'down');
      logger.warn('ai', 'Gemini flash-lite failed → next', { error: err.message });
    }
  }

  // 5. Gemma 26B MoE (1.5K RPD fast last resort)
  if (isUp('gemma_26b')) {
    try {
      logger.debug('ai', 'Trying gemma-4-26b-a4b-it');
      const result = await callGemini('gemma_26b', MODELS.GEMMA_4_26B, msgs, maxTokens);
      logger.info('ai', 'Gemma-26b succeeded', { tokens: result.tokens_used });
      return result;
    } catch (err) {
      if (err.message?.includes('429')) markProvider('gemma_26b', 'rate_limited');
      else                              markProvider('gemma_26b', 'down');
      logger.warn('ai', 'Gemma-26b failed → next', { error: err.message });
    }
  }

  // 6. Gemma 31B dense (heavy last resort)
  if (isUp('gemma_31b')) {
    try {
      logger.debug('ai', 'Trying gemma-4-31b-it');
      const result = await callGemini('gemma_31b', MODELS.GEMMA_4_31B, msgs, maxTokens);
      logger.info('ai', 'Gemma-31b succeeded', { tokens: result.tokens_used });
      return result;
    } catch (err) {
      if (err.message?.includes('429')) markProvider('gemma_31b', 'rate_limited');
      else                              markProvider('gemma_31b', 'down');
      logger.warn('ai', 'Gemma-31b failed → next', { error: err.message });
    }
  }

  // 7. Gemini 2.5 flash (ABSOLUTE last resort — 20 RPD, use sparingly)
  if (isUp('gemini')) {
    try {
      logger.debug('ai', 'Trying gemini-2.5-flash (LAST RESORT — 20 RPD)');
      const result = await callGemini('gemini', MODELS.GEMINI_FLASH, msgs, maxTokens);
      logger.info('ai', 'Gemini-2.5-flash succeeded', { tokens: result.tokens_used });
      return result;
    } catch (err) {
      if (err.message?.includes('429')) markProvider('gemini', 'rate_limited');
      else                              markProvider('gemini', 'down');
      logger.warn('ai', 'Gemini-2.5-flash failed', { error: err.message });
    }
  }

  // All providers exhausted
  logger.error('ai', 'All providers down');
  throw new Error('all_providers_down');
}

// ── STREAMING ─────────────────────────────────────────────────────────────────

async function stream(options = {}, onChunk) {
  const { messages, maxTokens = AGENT.MAX_TOKENS, systemPrompt = null } = options;

  if (!messages || !messages.length) throw new Error('messages required');
  if (typeof onChunk !== 'function') throw new Error('onChunk callback required');

  const msgs = systemPrompt
    ? [{ role: 'system', content: systemPrompt }, ...messages]
    : messages;

  // Groq only supports streaming — others fall back to complete()
  if (isUp('groq')) {
    try {
      logger.debug('ai:stream', 'Streaming via Groq');
      const groqStream = await groqClient().chat.completions.create({
        model:      MODELS.GROQ_BRAIN,
        messages:   msgs,
        max_tokens: maxTokens,
        stream:     true,
      });

      let fullText   = '';
      let tokensUsed = 0;

      for await (const chunk of groqStream) {
        const delta = chunk.choices[0]?.delta?.content || '';
        if (delta) {
          fullText += delta;
          onChunk(delta);
        }
        if (chunk.usage) tokensUsed = chunk.usage.total_tokens;
      }

      markOk('groq');
      return { text: fullText, model: MODELS.GROQ_BRAIN, tokens_used: tokensUsed };
    } catch (err) {
      const status = err.status || err.statusCode;
      if (status === 429) markProvider('groq', 'rate_limited');
      else                markProvider('groq', 'down');
      logger.warn('ai:stream', 'Groq stream failed → falling back to complete()', { error: err.message });
    }
  }

  // Fallback: complete() + emit full text as single chunk
  logger.debug('ai:stream', 'Falling back to complete() for streaming');
  const result = await complete(options);
  onChunk(result.text);
  return result;
}

// ── PUBLIC API ────────────────────────────────────────────────────────────────

function currentModel() {
  if (isUp('groq'))         return MODELS.GROQ_BRAIN;
  if (isUp('mistral_chat')) return MODELS.MISTRAL_CODE;
  if (isUp('gemini_lite'))  return MODELS.GEMINI_FLASH_LITE;
  if (isUp('gemma_26b'))    return MODELS.GEMMA_4_26B;
  if (isUp('gemma_31b'))    return MODELS.GEMMA_4_31B;
  if (isUp('gemini'))       return MODELS.GEMINI_FLASH;
  return null;
}

function modelStatus() {
  return Object.fromEntries(
    Object.entries(health).map(([provider, state]) => [
      provider,
      {
        status:    state.status,
        available: isUp(provider),
        downUntil: state.downUntil > 0
          ? new Date(state.downUntil).toISOString()
          : null,
      },
    ])
  );
}

module.exports = { complete, fim, stream, currentModel, modelStatus };

